#!/usr/bin/env python3
"""Add an emoji reaction to a Discord message via Wendy's internal API.

Usage:
    react MESSAGE_ID thumbsup
    react MESSAGE_ID fire
    react MESSAGE_ID heart
    react MESSAGE_ID 100
"""
import json
import os
import sys
import urllib.request

# Common emoji name -> unicode mapping
EMOJI_MAP = {
    "thumbsup": "\U0001f44d",
    "thumbsdown": "\U0001f44e",
    "fire": "\U0001f525",
    "heart": "\u2764\ufe0f",
    "laugh": "\U0001f602",
    "crying": "\U0001f62d",
    "joy": "\U0001f602",
    "eyes": "\U0001f440",
    "thinking": "\U0001f914",
    "100": "\U0001f4af",
    "party": "\U0001f389",
    "tada": "\U0001f389",
    "cool": "\U0001f60e",
    "sunglasses": "\U0001f60e",
    "rocket": "\U0001f680",
    "wave": "\U0001f44b",
    "clap": "\U0001f44f",
    "pray": "\U0001f64f",
    "skull": "\U0001f480",
    "sob": "\U0001f62d",
    "star": "\u2b50",
    "sparkles": "\u2728",
    "check": "\u2705",
    "x": "\u274c",
    "warning": "\u26a0\ufe0f",
    "question": "\u2753",
    "exclamation": "\u2757",
    "plus1": "\U0001f44d",
    "minus1": "\U0001f44e",
    "ok": "\U0001f44c",
    "muscle": "\U0001f4aa",
    "brain": "\U0001f9e0",
    "salute": "\U0001fae1",
    "moai": "\U0001f5ff",
    "nerd": "\U0001f913",
    "pensive": "\U0001f614",
    "smirk": "\U0001f60f",
    "wink": "\U0001f609",
    "scream": "\U0001f631",
    "angry": "\U0001f620",
    "sweat": "\U0001f613",
    "sleepy": "\U0001f634",
    "poop": "\U0001f4a9",
    "ghost": "\U0001f47b",
    "alien": "\U0001f47d",
    "robot": "\U0001f916",
    "cat": "\U0001f431",
    "dog": "\U0001f436",
    "bee": "\U0001f41d",
    "butterfly": "\U0001f98b",
    "rainbow": "\U0001f308",
    "sun": "\u2600\ufe0f",
    "moon": "\U0001f319",
    "cloud": "\u2601\ufe0f",
    "umbrella": "\u2602\ufe0f",
    "snowflake": "\u2744\ufe0f",
    "pizza": "\U0001f355",
    "coffee": "\u2615",
    "beer": "\U0001f37a",
    "wine": "\U0001f377",
    "cake": "\U0001f370",
    "cookie": "\U0001f36a",
    "popcorn": "\U0001f37f",
    "art": "\U0001f3a8",
    "music": "\U0001f3b5",
    "guitar": "\U0001f3b8",
    "mic": "\U0001f3a4",
    "movie": "\U0001f3ac",
    "game": "\U0001f3ae",
    "trophy": "\U0001f3c6",
    "medal": "\U0001f3c5",
    "crown": "\U0001f451",
    "gem": "\U0001f48e",
    "money": "\U0001f4b0",
    "bulb": "\U0001f4a1",
    "lightbulb": "\U0001f4a1",
    "bomb": "\U0001f4a3",
    "hammer": "\U0001f528",
    "wrench": "\U0001f527",
    "gear": "\u2699\ufe0f",
    "link": "\U0001f517",
    "lock": "\U0001f512",
    "key": "\U0001f511",
    "mag": "\U0001f50d",
    "pin": "\U0001f4cc",
    "clipboard": "\U0001f4cb",
    "memo": "\U0001f4dd",
    "book": "\U0001f4d6",
    "flag": "\U0001f3f4",
    "triangular_flag": "\U0001f6a9",
    "construction": "\U0001f6a7",
    "zzz": "\U0001f4a4",
}


def main():
    if len(sys.argv) < 3:
        print("Usage: react MESSAGE_ID EMOJI_NAME", file=sys.stderr)
        print("       react MESSAGE_ID thumbsup", file=sys.stderr)
        print(f"\nAvailable emoji names: {', '.join(sorted(EMOJI_MAP))}", file=sys.stderr)
        sys.exit(1)

    message_id = sys.argv[1]
    emoji_name = sys.argv[2]

    # Resolve emoji: check the map, otherwise pass through as-is (for unicode or custom emoji)
    emoji = EMOJI_MAP.get(emoji_name, emoji_name)

    channel_id = os.environ.get("WENDY_CHANNEL_ID")
    if not channel_id:
        print("Error: WENDY_CHANNEL_ID not set", file=sys.stderr)
        sys.exit(1)

    port = os.environ.get("WENDY_PROXY_PORT", "8945")

    body = {
        "channel_id": channel_id,
        "actions": [{"type": "add_reaction", "message_id": message_id, "emoji": emoji}],
    }

    data = json.dumps(body).encode()
    req = urllib.request.Request(
        f"http://localhost:{port}/api/send_message",
        data=data,
        headers={"Content-Type": "application/json"},
    )
    try:
        resp = urllib.request.urlopen(req)
        result = json.loads(resp.read().decode())
        if not result.get("success"):
            print(json.dumps(result, indent=2), file=sys.stderr)
            sys.exit(1)
    except urllib.error.HTTPError as e:
        print(f"Error ({e.code}): {e.read().decode()}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
