# =============================================================================
# wendy (bot service) -- from /srv/secrets/wendy/bot.env
# =============================================================================

# Discord bot token
DISCORD_TOKEN=

# Channel configuration (JSON array)
# Each entry: id, name, mode (chat|full), model (opus|sonnet|haiku), beads_enabled
WENDY_CHANNEL_CONFIG='[{"id":"1234567890123456789","name":"coding","mode":"full","model":"opus","beads_enabled":true}]'

# Deploy tokens for wendy-web service (must match DEPLOY_TOKEN in sites.env)
WENDY_DEPLOY_TOKEN=
WENDY_GAMES_TOKEN=    # can be same as WENDY_DEPLOY_TOKEN

# Gemini API key for /api/analyze_file (images, audio, video)
GEMINI_API_KEY=

# Bot identity
WENDY_BOT_NAME=Wendy
WENDY_WEB_URL=https://wendy.monster

# Guild IDs for full message logging (comma-separated Discord guild IDs)
# MESSAGE_LOGGER_GUILDS=

# Claude OAuth token -- replaces interactive `claude login`
# Generate with: claude setup-token
# Also requires {"hasCompletedOnboarding": true} in ~/.claude.json (entrypoint handles this)
CLAUDE_CODE_OAUTH_TOKEN=

# Claude session sync
# CLAUDE_SYNC_KEY=

# =============================================================================
# wendy-web (sites + games + brain) -- from /srv/secrets/wendy/sites.env
# =============================================================================

# Deploy token -- must match WENDY_DEPLOY_TOKEN above
DEPLOY_TOKEN=

# Brain feed credentials
BRAIN_ACCESS_CODE=      # code users type to log in (e.g. wendyiscool)
BRAIN_SECRET=           # signing secret: openssl rand -hex 32

# GitHub webhook signature validation (optional)
WEBHOOK_SECRET=
