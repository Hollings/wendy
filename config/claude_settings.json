{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Task tool is disabled. Use bd (beads) for background tasks instead. Run: bd create \"description\" in Bash. Docs: /app/config/docs/bd_usage.md' >&2 && exit 2"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/remind_analyze_file.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/log_bash_tool.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/pre_compact.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/journal_stop_check.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/prompt_bookkeeping.sh"
          }
        ]
      }
    ]
  }
}
